<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="#121212">
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MusicPro"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Content Area -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Mini Player -->
    <LinearLayout
        android:id="@+id/miniPlayer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="8dp"
        android:background="#282828"
        android:visibility="gone">
        <ImageView
            android:id="@+id/ivMiniAlbum"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#333333"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="12dp">
            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/tvMiniArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B3B3B3"
                android:textSize="12sp"
                android:singleLine="true"/>
        </LinearLayout>
        <TextView
            android:id="@+id/btnMiniPlay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="▶"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>
        <TextView
            android:id="@+id/btnMiniNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="⏭"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#181818"
        android:gravity="center">
        <LinearLayout
            android:id="@+id/navLocal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="🎵"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/navLocalText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_local"
                android:textColor="#1DB954"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navOnline"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="🔍"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/navOnlineText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_online"
                android:textColor="#B3B3B3"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navRadio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="📻"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/navRadioText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_radio"
                android:textColor="#B3B3B3"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navMine"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="❤️"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/navMineText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_mine"
                android:textColor="#B3B3B3"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
